# ============================================================================
# KuberCoin Production Environment Configuration
# Domain: kuber-coin.com
# ============================================================================
#
# Copy this file to .env.production and fill in all values before deployment.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
MAIN_DOMAIN=kuber-coin.com
WALLET_DOMAIN=wallet.kuber-coin.com
EXPLORER_DOMAIN=explorer.kuber-coin.com
NODE_DOMAIN=node.kuber-coin.com
API_DOMAIN=api.kuber-coin.com
WS_DOMAIN=ws.kuber-coin.com
RPC_DOMAIN=rpc.kuber-coin.com
DOCS_DOMAIN=docs.kuber-coin.com
DAPP_DOMAIN=dapp.kuber-coin.com
OPS_DOMAIN=ops.kuber-coin.com

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
KUBERCOIN_ACME_EMAIL=connect@kuber-coin.com

# =============================================================================
# NODE CONFIGURATION
# =============================================================================
KUBERCOIN_NETWORK=mainnet
RUST_LOG=info,kubercoin=info

# API Keys (comma-separated, each key must be 32+ characters)
# Generate with: openssl rand -hex 32
KUBERCOIN_API_KEYS=

# =============================================================================
# RPC AUTHENTICATION
# =============================================================================
# Generate password hash with: caddy hash-password
RPC_USER=kubercoin_rpc
RPC_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
RPC_AUTH_USER=admin
RPC_AUTH_HASH=

# =============================================================================
# OPS AUTHENTICATION
# =============================================================================
OPS_AUTH_USER=admin
OPS_AUTH_HASH=

# =============================================================================
# DATABASE (Optional)
# =============================================================================
POSTGRES_USER=kubercoin
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD

# =============================================================================
# MONITORING (Optional)
# =============================================================================
GRAFANA_USER=kubercoin_admin
GRAFANA_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD

# =============================================================================
# DEMO SETTINGS (Disable in production)
# =============================================================================
KUBERCOIN_DEMO_PEERS=0
KUBERCOIN_DEMO_PING_INTERVAL_SECS=60

# =============================================================================
# WEB APP ENVIRONMENT VARIABLES
# =============================================================================
# Public URLs exposed to browsers
NEXT_PUBLIC_NODE_URL=https://node.kuber-coin.com
NEXT_PUBLIC_RPC_URL=https://rpc.kuber-coin.com
NEXT_PUBLIC_WS_URL=wss://node.kuber-coin.com/ws
NEXT_PUBLIC_EXPLORER_URL=https://explorer.kuber-coin.com
NEXT_PUBLIC_WALLET_URL=https://wallet.kuber-coin.com
NEXT_PUBLIC_DOCS_URL=https://docs.kuber-coin.com
NEXT_PUBLIC_DAPP_URL=https://dapp.kuber-coin.com

# Internal service URLs (used server-side)
KUBERCOIN_RPC_URL=http://node:8332
KUBERCOIN_WALLET_API_URL=http://node:8081
KUBERCOIN_WS_URL=ws://node:9090/ws
KUBERCOIN_METRICS_URL=http://node:9091/metrics
