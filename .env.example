# Kubercoin Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# Network Configuration
KUBERCOIN_NETWORK=testnet  # Options: mainnet, testnet, regtest

# RPC Authentication
RPC_USER=admin
RPC_PASSWORD=changeme_secure_password_here

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_changeme

# PostgreSQL (for indexer)
POSTGRES_USER=kubercoin
POSTGRES_PASSWORD=changeme_secure_db_password

# Node Configuration
RUST_LOG=info  # Options: trace, debug, info, warn, error

# Optional: Custom ports (if defaults conflict)
# P2P_PORT=8633
# RPC_PORT=8332
# REST_PORT=8080
# WS_PORT=9090
# METRICS_PORT=9091
