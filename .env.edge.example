# Edge proxy environment template
# Copy to .env.edge and fill in.

# Subdomain-based routing (recommended)
# Create DNS A/AAAA records for these names pointing to your server.
EXPLORER_DOMAIN=explorer.kuber-coin.com
WALLET_DOMAIN=wallet.kuber-coin.com
OPS_DOMAIN=ops.kuber-coin.com
API_DOMAIN=api.kuber-coin.com
WS_DOMAIN=ws.kuber-coin.com

# Optional RPC hostname (recommended to keep disabled unless needed)
# RPC_DOMAIN=rpc.kuber-coin.com

# Optional ACME email (recommended)
KUBERCOIN_ACME_EMAIL=connect@kuber-coin.com

# Protect /ops with basic auth
OPS_AUTH_USER=opsadmin
# Generate this with:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "your-strong-password"
OPS_AUTH_HASH=REPLACE_WITH_CADDY_HASH

# Optional: protect /rpc with basic auth (recommended if you expose it at all)
# RPC_AUTH_USER=rpcadmin
# RPC_AUTH_HASH=REPLACE_WITH_CADDY_HASH
