{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "fuzz-check-all",
			"type": "shell",
			"command": "cargo",
			"args": [
				"check",
				"--manifest-path",
				"core/tests/fuzz/Cargo.toml",
				"--bins"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "fuzz-local-sweep",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"tools\\scripts\\fuzz_smoke_all.ps1",
				"-Runs",
				"1"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "fuzz-wsl-sweep",
			"type": "shell",
			"command": "wsl.exe",
			"args": [
				"bash",
				"-lc",
				"cd \"$(wslpath '${workspaceFolder}')\" && bash tools/scripts/fuzz_smoke_all.sh"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "fuzz-check-target",
			"type": "shell",
			"command": "cargo",
			"args": [
				"check",
				"--manifest-path",
				"core/tests/fuzz/Cargo.toml",
				"--bin",
				"${input:fuzzTarget}"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "fuzz-wsl-target",
			"type": "shell",
			"command": "wsl.exe",
			"args": [
				"bash",
				"-lc",
				"cd \"$(wslpath '${workspaceFolder}')\" && RUNS='${input:fuzzRuns}' bash tools/scripts/fuzz_smoke_all.sh ${input:fuzzTarget}"
			],
			"group": "test",
			"problemMatcher": []
