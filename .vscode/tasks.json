		{
			"label": "node-run-no-p2p (local ports)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"& .\\target\\release\\kubercoin.exe node --no-p2p"
			],
			"isBackground": true,
			"problemMatcher": {
				"owner": "kubercoin-node",
				"pattern": {
					"regexp": "^\\s*(ERROR|Error|error):\\s+(.*)$",
					"severity": 1,
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "KuberCoin Network Node",
					"endsPattern": "✓ HTTP API started"
				}
			},
			"group": "test",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"KUBERCOIN_HTTP_PORT": "18080",
					"KUBERCOIN_WS_PORT": "19090",
					"KUBERCOIN_API_AUTH_ENABLED": "false",
					"KUBERCOIN_API_KEYS": "public_test_key_not_a_secret",
					"KUBERCOIN_TEST_MODE": "1"
				}
