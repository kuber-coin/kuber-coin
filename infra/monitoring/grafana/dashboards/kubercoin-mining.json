{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Hash Rate (H/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(kubercoin_hashes_total[5m])",
          "legendFormat": "Hash Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Hs",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Blocks Mined",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "kubercoin_blocks_mined_total",
          "legendFormat": "Blocks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Difficulty",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "kubercoin_difficulty",
          "legendFormat": "Difficulty"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Block Time (seconds)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "kubercoin_last_block_time_seconds",
          "legendFormat": "Block Time"
        },
        {
          "expr": "600",
          "legendFormat": "Target (10m)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Block Reward (KUBER)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "kubercoin_block_reward",
          "legendFormat": "Reward"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Supply (KUBER)",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "kubercoin_total_supply",
          "legendFormat": "Supply"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 21000000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 5000000 },
              { "color": "yellow", "value": 15000000 },
              { "color": "red", "value": 20000000 }
            ]
          }
        }
      }
    },
    {
      "title": "Mempool Size",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kubercoin_mempool_size",
          "legendFormat": "Transactions"
        },
        {
          "expr": "kubercoin_mempool_bytes",
          "legendFormat": "Size (bytes)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Connected Peers",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "kubercoin_peers",
          "legendFormat": "Peers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 8 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["kubercoin", "mining"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "KuberCoin Mining",
  "uid": "kubercoin-mining",
  "version": 1
}
