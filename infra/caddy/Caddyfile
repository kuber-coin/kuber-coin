{
  # Global options
  email {$KUBERCOIN_ACME_EMAIL}
  servers {
    protocols h1 h2
  }
}

(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Frame-Options "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
  }
}

# Main Landing (example.com)
{$MAIN_DOMAIN} {
  encode zstd gzip
  import security_headers
  reverse_proxy web-unified:3000
  respond /health "ok" 200
  log { output stdout; format console }
}

# Explorer UI
{$EXPLORER_DOMAIN} {
  encode zstd gzip
  import security_headers
  reverse_proxy explorer-web:3000
  respond /health "ok" 200
  log { output stdout; format console }
}

# Wallet UI
{$WALLET_DOMAIN} {
  encode zstd gzip
  import security_headers
  reverse_proxy wallet-web:3000
  respond /health "ok" 200
  log { output stdout; format console }
}

# Ops UI (protected)
{$OPS_DOMAIN} {
  encode zstd gzip
  import security_headers
  basicauth {
    {$OPS_AUTH_USER} {$OPS_AUTH_HASH}
  }
  reverse_proxy ops-web:3000
  respond /health "ok" 200
  log { output stdout; format console }
}

