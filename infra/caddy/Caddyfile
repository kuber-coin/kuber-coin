# Public REST API
{$API_DOMAIN} {
  encode zstd gzip
  import security_headers
  reverse_proxy node:8634
  respond /health "ok" 200
  log { output stdout; format console }
}

# Public WebSocket endpoint
{$WS_DOMAIN} {
  encode zstd gzip
  import security_headers
  respond /health "ok" 200
  respond "websocket endpoint unavailable" 404
  log { output stdout; format console }
}

# Optional RPC endpoint (disabled unless credentials provided)
{$RPC_DOMAIN} {
  encode zstd gzip
  import security_headers

  @rpcAuthEnabled expression `{env.RPC_AUTH_USER} != "" && {env.RPC_AUTH_HASH} != ""`
  handle @rpcAuthEnabled {
    basicauth {
      {$RPC_AUTH_USER} {$RPC_AUTH_HASH}
    }
    reverse_proxy node:8634
  }
  respond "not found" 404
  log { output stdout; format console }
}
