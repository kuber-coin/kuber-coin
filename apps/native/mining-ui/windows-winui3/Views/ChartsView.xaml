<Page
    x:Class="KuberCoinMiner.Views.ChartsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="24">

            <!-- Time Range Selector -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <RadioButton Content="24 Hours" 
                            IsChecked="True"
                            GroupName="TimeRange"
                            Tag="24h"
                            Checked="TimeRange_Changed"/>
                <RadioButton Content="7 Days" 
                            GroupName="TimeRange"
                            Tag="7d"
                            Checked="TimeRange_Changed"/>
                <RadioButton Content="30 Days" 
                            GroupName="TimeRange"
                            Tag="30d"
                            Checked="TimeRange_Changed"/>
                <RadioButton Content="All Time" 
                            GroupName="TimeRange"
                            Tag="all"
                            Checked="TimeRange_Changed"/>
            </StackPanel>

            <!-- Profit Chart -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <TextBlock Text="Profitability History" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Right"
                                   Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Total Profit" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.TotalProfit, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Avg Daily" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.AvgDailyProfit, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource BrandOrange}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <lvc:CartesianChart Series="{x:Bind ViewModel.ProfitSeries, Mode=OneWay}"
                                       Height="300"
                                       XAxes="{x:Bind ViewModel.XAxes}"
                                       YAxes="{x:Bind ViewModel.YAxes}"/>
                </StackPanel>
            </Border>

            <!-- Hashrate Chart -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <TextBlock Text="Hashrate History" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Right"
                                   Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Current" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentHashrate, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Average" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.AverageHashrate, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <lvc:CartesianChart Series="{x:Bind ViewModel.HashrateSeries, Mode=OneWay}"
                                       Height="300"
                                       XAxes="{x:Bind ViewModel.XAxes}"
                                       YAxes="{x:Bind ViewModel.HashrateYAxes}"/>
                </StackPanel>
            </Border>

            <!-- Temperature Chart -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <TextBlock Text="GPU Temperature History" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Right"
                                   Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Max Temp" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.MaxTemperature, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Avg Temp" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.AvgTemperature, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <lvc:CartesianChart Series="{x:Bind ViewModel.TemperatureSeries, Mode=OneWay}"
                                       Height="300"
                                       XAxes="{x:Bind ViewModel.XAxes}"
                                       YAxes="{x:Bind ViewModel.TemperatureYAxes}"/>
                </StackPanel>
            </Border>

            <!-- Power Consumption Chart -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <TextBlock Text="Power Consumption" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Right"
                                   Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Current" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentPower, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Est. Monthly Cost" 
                                          FontSize="12" 
                                          Foreground="#6B7280"/>
                                <TextBlock Text="{x:Bind ViewModel.MonthlyCost, Mode=OneWay}" 
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="#EF4444"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <lvc:CartesianChart Series="{x:Bind ViewModel.PowerSeries, Mode=OneWay}"
                                       Height="300"
                                       XAxes="{x:Bind ViewModel.XAxes}"
                                       YAxes="{x:Bind ViewModel.PowerYAxes}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
