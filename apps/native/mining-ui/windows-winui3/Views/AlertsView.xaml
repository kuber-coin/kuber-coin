<Page
    x:Class="KuberCoinMiner.Views.AlertsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Alert Configuration" 
                      FontSize="24" 
                      FontWeight="SemiBold"
                      VerticalAlignment="Center"/>
            <Button HorizontalAlignment="Right"
                   Style="{StaticResource AccentButtonStyle}"
                   Click="AddAlert_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        <TextBlock Text="Add Alert Rule"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24">

                <!-- Global Alert Settings -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Global Settings" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        
                        <CheckBox Content="Enable Desktop Notifications"
                                 IsChecked="{x:Bind ViewModel.EnableNotifications, Mode=TwoWay}"/>
                        
                        <CheckBox Content="Play Sound on Alert"
                                 IsChecked="{x:Bind ViewModel.PlaySound, Mode=TwoWay}"/>
                        
                        <CheckBox Content="Send Email Alerts"
                                 IsChecked="{x:Bind ViewModel.SendEmail, Mode=TwoWay}"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Email Address" FontSize="14"/>
                            <TextBox Text="{x:Bind ViewModel.EmailAddress, Mode=TwoWay}"
                                    PlaceholderText="your@email.com"
                                    IsEnabled="{x:Bind ViewModel.SendEmail, Mode=OneWay}"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Alert Check Interval" FontSize="14"/>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.CheckInterval, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Every 30 seconds"/>
                                <ComboBoxItem Content="Every minute"/>
                                <ComboBoxItem Content="Every 5 minutes"/>
                                <ComboBoxItem Content="Every 15 minutes"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Alert Rules -->
                <TextBlock Text="Alert Rules" 
                          FontSize="18" 
                          FontWeight="SemiBold"/>

                <ItemsControl ItemsSource="{x:Bind ViewModel.AlertRules, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Rule Header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="{Binding Icon}" 
                                                     FontSize="20"
                                                     Foreground="{Binding Severity}"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" 
                                                          FontSize="12" 
                                                          Foreground="#6B7280"
                                                          Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" 
                                                   HorizontalAlignment="Right"
                                                   Spacing="8">
                                            <ToggleSwitch IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                                         OnContent=""
                                                         OffContent=""
                                                         MinWidth="44"/>
                                            <Button Style="{StaticResource IconButtonStyle}">
                                                <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButtonStyle}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Rule Configuration -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.ColumnSpacing>16</Grid.ColumnSpacing>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Condition" FontSize="12" Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding Condition}" 
                                                      FontSize="14" 
                                                      FontWeight="SemiBold"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Threshold" FontSize="12" Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding Threshold}" 
                                                      FontSize="14" 
                                                      FontWeight="SemiBold"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Last Triggered" FontSize="12" Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding LastTriggered}" 
                                                      FontSize="14" 
                                                      FontWeight="SemiBold"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recent Alerts History -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Recent Alerts" 
                                  FontSize="18" 
                                  FontWeight="SemiBold"/>
                        
                        <ListView ItemsSource="{x:Bind ViewModel.RecentAlerts, Mode=OneWay}"
                                 SelectionMode="None"
                                 MaxHeight="400">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                 Glyph="&#xE7BA;"
                                                 FontSize="16"
                                                 Foreground="{Binding SeverityColor}"
                                                 Margin="0,0,12,0"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Message}" 
                                                      FontSize="14"
                                                      FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Details}" 
                                                      FontSize="12"
                                                      Foreground="#6B7280"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                  Text="{Binding Timestamp}"
                                                  FontSize="12"
                                                  Foreground="#6B7280"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
