<Page
    x:Class="KuberCoinMiner.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="24">
            
            <!-- Mining Control -->
            <Grid HorizontalAlignment="Center" Margin="0,24,0,0">
                <Grid Width="200" Height="200">
                    <!-- Progress Ring -->
                    <ProgressRing IsActive="{x:Bind ViewModel.IsMining, Mode=OneWay}"
                                 Width="200"
                                 Height="200"
                                 Foreground="{StaticResource BrandOrange}"/>
                    
                    <!-- Center Button -->
                    <Button Width="120" Height="120"
                           CornerRadius="60"
                           Background="{ThemeResource CardBackground}"
                           BorderBrush="{StaticResource BrandOrange}"
                           BorderThickness="3"
                           Click="ToggleMining_Click">
                        <StackPanel>
                            <FontIcon Glyph="{x:Bind ViewModel.MiningIcon, Mode=OneWay}"
                                     FontSize="32"
                                     Foreground="{StaticResource BrandOrange}"/>
                            <TextBlock Text="{x:Bind ViewModel.MiningStatus, Mode=OneWay}"
                                      FontSize="14"
                                      Foreground="#6B7280"
                                      HorizontalAlignment="Center"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Metrics Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.ColumnSpacing>16</Grid.ColumnSpacing>

                <!-- GPU Count -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.GpuCount, Mode=OneWay}"
                                  Style="{StaticResource MetricNumberStyle}"/>
                        <TextBlock Text="GPU'S"
                                  Style="{StaticResource MetricLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- CPU Count -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.CpuCount, Mode=OneWay}"
                                  Style="{StaticResource MetricNumberStyle}"/>
                        <TextBlock Text="CPU"
                                  Style="{StaticResource MetricLabelStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Current Profitability -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="CURRENT PROFITABILITY"
                                  Style="{StaticResource MetricLabelStyle}"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,12"/>
                        <TextBlock FontSize="28" FontWeight="SemiBold">
                            <Run Text="{x:Bind ViewModel.DailyProfit, Mode=OneWay}"/>
                            <Run Text=" BTC / 24h" FontSize="16" Foreground="#6B7280"/>
                        </TextBlock>
                        <TextBlock Text="{x:Bind ViewModel.DailyProfitUsd, Mode=OneWay}"
                                  FontSize="16"
                                  Foreground="#6B7280"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Unpaid Balance -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="UNPAID BALANCE"
                              Style="{StaticResource MetricLabelStyle}"
                              HorizontalAlignment="Left"
                              Margin="0,0,0,12"/>
                    <TextBlock FontSize="32" FontWeight="SemiBold">
                        <Run Text="{x:Bind ViewModel.UnpaidBalance, Mode=OneWay}"/>
                        <Run Text=" BTC" FontSize="20" Foreground="#6B7280"/>
                    </TextBlock>
                    <TextBlock Text="{x:Bind ViewModel.UnpaidBalanceUsd, Mode=OneWay}"
                              FontSize="18"
                              Foreground="#6B7280"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Device List -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="MINING DEVICES"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"/>
                    
                    <ListView ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                             SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="0,0,0,12" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Device" Foreground="#6B7280" Grid.Column="0"/>
                                <TextBlock Text="Hashrate" Foreground="#6B7280" Grid.Column="1"/>
                                <TextBlock Text="Temp" Foreground="#6B7280" Grid.Column="2"/>
                                <TextBlock Text="Power" Foreground="#6B7280" Grid.Column="3"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Grid.Column="0"/>
                                    <TextBlock Text="{Binding Hashrate}" Grid.Column="1"/>
                                    <TextBlock Text="{Binding Temperature}" Grid.Column="2"/>
                                    <TextBlock Text="{Binding Power}" Grid.Column="3"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Active Pool Info -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="ACTIVE POOL" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{x:Bind ViewModel.ActivePool, Mode=OneWay}"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="SHARE ACCEPTANCE" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{x:Bind ViewModel.ShareAcceptance, Mode=OneWay}"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="#10B981"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
