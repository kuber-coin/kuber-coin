<Page
    x:Class="KuberCoinMiner.Views.OverclockingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="24">
            
            <!-- Warning Banner -->
            <InfoBar Title="Overclocking Warning"
                    Message="Overclocking may void your warranty and can damage hardware if not done carefully. Always monitor temperatures."
                    Severity="Warning"
                    IsOpen="True"
                    IsClosable="False"/>

            <!-- GPU Overclocking Cards -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.GpuDevices, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <StackPanel Spacing="20">
                                
                                <!-- Device Header -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="18" 
                                                  FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Model}" 
                                                  FontSize="12" 
                                                  Foreground="#6B7280"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <ToggleSwitch Grid.Column="1"
                                                 IsOn="{Binding IsOverclockEnabled, Mode=TwoWay}"
                                                 Header="Enable OC"/>
                                </Grid>

                                <!-- Status Indicators -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Temperature" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Temperature}" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Power Draw" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding PowerDraw}" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Core Clock" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CoreClock}" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Memory Clock" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding MemoryClock}" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Power Limit Slider -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="Power Limit" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding PowerLimit}" 
                                                  HorizontalAlignment="Right"
                                                  FontSize="14"
                                                  Foreground="{StaticResource BrandOrange}"/>
                                    </Grid>
                                    <Slider Minimum="50" 
                                           Maximum="120" 
                                           Value="{Binding PowerLimit, Mode=TwoWay}"
                                           StepFrequency="1"
                                           TickFrequency="10"
                                           TickPlacement="BottomRight"
                                           IsEnabled="{Binding IsOverclockEnabled}"/>
                                </StackPanel>

                                <!-- Core Clock Offset Slider -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="Core Clock Offset" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14">
                                            <Run Text="{Binding CoreClockOffset}"/>
                                            <Run Text=" MHz" Foreground="#6B7280"/>
                                        </TextBlock>
                                    </Grid>
                                    <Slider Minimum="-300" 
                                           Maximum="300" 
                                           Value="{Binding CoreClockOffset, Mode=TwoWay}"
                                           StepFrequency="10"
                                           TickFrequency="50"
                                           TickPlacement="BottomRight"
                                           IsEnabled="{Binding IsOverclockEnabled}"/>
                                </StackPanel>

                                <!-- Memory Clock Offset Slider -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="Memory Clock Offset" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14">
                                            <Run Text="{Binding MemoryClockOffset}"/>
                                            <Run Text=" MHz" Foreground="#6B7280"/>
                                        </TextBlock>
                                    </Grid>
                                    <Slider Minimum="-1000" 
                                           Maximum="1500" 
                                           Value="{Binding MemoryClockOffset, Mode=TwoWay}"
                                           StepFrequency="25"
                                           TickFrequency="250"
                                           TickPlacement="BottomRight"
                                           IsEnabled="{Binding IsOverclockEnabled}"/>
                                </StackPanel>

                                <!-- Fan Speed Slider -->
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="Fan Speed" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding FanSpeed}" 
                                                  HorizontalAlignment="Right"
                                                  FontSize="14"
                                                  Foreground="{StaticResource BrandOrange}"/>
                                    </Grid>
                                    <Slider Minimum="0" 
                                           Maximum="100" 
                                           Value="{Binding FanSpeed, Mode=TwoWay}"
                                           StepFrequency="5"
                                           TickFrequency="10"
                                           TickPlacement="BottomRight"
                                           IsEnabled="{Binding IsOverclockEnabled}"/>
                                    <TextBlock Text="0 = Auto control" 
                                              FontSize="11" 
                                              Foreground="#6B7280"/>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.ColumnSpacing>12</Grid.ColumnSpacing>

                                    <Button Content="Apply Settings" 
                                           Grid.Column="0"
                                           HorizontalAlignment="Stretch"
                                           Style="{StaticResource AccentButtonStyle}"/>
                                    <Button Content="Save Profile" 
                                           Grid.Column="1"
                                           HorizontalAlignment="Stretch"/>
                                    <Button Content="Reset to Default" 
                                           Grid.Column="2"
                                           HorizontalAlignment="Stretch"/>
                                </Grid>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
