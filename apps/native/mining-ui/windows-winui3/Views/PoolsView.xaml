<Page
    x:Class="KuberCoinMiner.Views.PoolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Add Button -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Mining Pools" 
                      FontSize="24" 
                      FontWeight="SemiBold"
                      VerticalAlignment="Center"/>
            <Button HorizontalAlignment="Right"
                   Style="{StaticResource AccentButtonStyle}"
                   Click="AddPool_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        <TextBlock Text="Add Pool"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>

        <!-- Pools List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Pools, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Pool Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="{Binding StatusColor}"
                                           Width="12"
                                           Height="12"
                                           CornerRadius="6"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" 
                                                  FontSize="18" 
                                                  FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Url}" 
                                                  FontSize="12" 
                                                  Foreground="#6B7280"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                        <ToggleSwitch IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                                     OnContent=""
                                                     OffContent=""
                                                     MinWidth="44"/>
                                        <Button Style="{StaticResource IconButtonStyle}">
                                            <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButtonStyle}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Pool Stats -->
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Status" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Status}" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Accepted Shares" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding AcceptedShares}" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Rejected Shares" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding RejectedShares}" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Uptime" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Uptime}" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Pool Configuration -->
                                <StackPanel Grid.Row="2" Spacing="12">
                                    <Expander Header="Pool Configuration" 
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Stretch">
                                        <StackPanel Spacing="16" Margin="0,16,0,0">
                                            
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Worker Name" FontSize="14"/>
                                                <TextBox Text="{Binding WorkerName, Mode=TwoWay}"
                                                        PlaceholderText="e.g., rig001"/>
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Wallet Address" FontSize="14"/>
                                                <TextBox Text="{Binding WalletAddress, Mode=TwoWay}"
                                                        PlaceholderText="Enter your wallet address"/>
                                            </StackPanel>

                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Priority" FontSize="14"/>
                                                <ComboBox SelectedIndex="{Binding Priority, Mode=TwoWay}"
                                                         HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="Primary"/>
                                                    <ComboBoxItem Content="Failover 1"/>
                                                    <ComboBoxItem Content="Failover 2"/>
                                                    <ComboBoxItem Content="Failover 3"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <CheckBox Content="Auto-restart on connection failure"
                                                     IsChecked="{Binding AutoRestart, Mode=TwoWay}"/>

                                            <CheckBox Content="Enable TLS/SSL"
                                                     IsChecked="{Binding UseSsl, Mode=TwoWay}"/>

                                        </StackPanel>
                                    </Expander>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Page>
