<Window
    x:Class="KuberCoinMiner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="{ThemeResource AppChromeBackground}" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="24">
                <TextBlock Text="KuberCoin Miner" 
                          FontSize="16" 
                          FontWeight="SemiBold" 
                          Foreground="{ThemeResource AppForeground}"
                          VerticalAlignment="Center"/>
                
                <NavigationView IsBackButtonVisible="Collapsed"
                               IsSettingsVisible="False"
                               IsPaneToggleButtonVisible="False"
                               SelectionChanged="NavView_SelectionChanged"
                               PaneDisplayMode="Top">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="Dashboard" Tag="Dashboard" IsSelected="True"/>
                        <NavigationViewItem Content="Devices" Tag="Devices"/>
                        <NavigationViewItem Content="Pools" Tag="Pools"/>
                        <NavigationViewItem Content="Overclocking" Tag="Overclocking"/>
                        <NavigationViewItem Content="Charts" Tag="Charts"/>
                        <NavigationViewItem Content="Alerts" Tag="Alerts"/>
                    </NavigationView.MenuItems>
                </NavigationView>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="&#xEA8F;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource IconButtonStyle}" Foreground="{ThemeResource AppForeground}"/>
                <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource IconButtonStyle}" Foreground="{ThemeResource AppForeground}"/>
            </StackPanel>
        </Grid>

        <!-- Content Frame -->
        <Frame x:Name="ContentFrame" Grid.Row="1" Padding="24"/>
    </Grid>
</Window>
