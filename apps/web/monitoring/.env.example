# Node JSON-RPC endpoint
KUBERCOIN_RPC_URL=http://localhost:8332

# API key for RPC auth (Bearer or raw token)
KUBERCOIN_API_KEY=

# Optional: Basic auth for RPC
# KUBERCOIN_RPC_USER=
# KUBERCOIN_RPC_PASS=

# Prometheus metrics endpoint
KUBERCOIN_PROMETHEUS_URL=http://localhost:9091/metrics

# Optional: client-side auto-refresh interval
NEXT_PUBLIC_REFRESH_MS=5000
