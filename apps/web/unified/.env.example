# KuberCoin Web Unified - Environment Configuration
# Copy to .env.local for local development

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
KUBERCOIN_WALLET_API_URL=http://localhost:8081
KUBERCOIN_RPC_URL=http://localhost:8332
KUBERCOIN_WS_URL=ws://localhost:9090/ws
FAUCET_URL=http://localhost:3001

# =============================================================================
# PRODUCTION (example.com)
# These are set via your production deployment environment
# =============================================================================
# Public URLs (exposed to browser)
# NEXT_PUBLIC_NODE_URL=https://node.example.com
# NEXT_PUBLIC_RPC_URL=https://rpc.example.com
# NEXT_PUBLIC_WS_URL=wss://node.example.com/ws
# NEXT_PUBLIC_EXPLORER_URL=https://explorer.example.com
# NEXT_PUBLIC_WALLET_URL=https://wallet.example.com
# NEXT_PUBLIC_DOCS_URL=https://docs.example.com

# Internal URLs (server-side only)
# KUBERCOIN_WALLET_API_URL=http://node:8081
# KUBERCOIN_RPC_URL=http://node:8332
# KUBERCOIN_WS_URL=ws://node:9090/ws
