{
  "name": "@kubercoin/client",
  "version": "1.0.19",
  "description": "Official JavaScript/TypeScript client for the KuberCoin node RPC and REST API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "node --test src/index.test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "kubercoin",
    "blockchain",
    "cryptocurrency",
    "rpc",
    "bitcoin"
  ],
  "author": "KuberCoin Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubercoin/kubercoin.git",
    "directory": "apps/sdk/packages/js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
