# ---------------------------------------------------------------------------
# KuberCoin Testnet Environment Example
# ---------------------------------------------------------------------------
# Copy to .env.testnet and adjust values for your local or hosted testnet node.
#
# Usage:
#   docker compose -f docker-compose.testnet.yml --env-file .env.testnet up -d

# Network
KUBERCOIN_NETWORK=testnet

# Optional peer bootstrap
# KUBERCOIN_INITIAL_PEERS=seed1.kuber-coin.com:18633,seed2.kuber-coin.com:18633

# Bind addresses inside the container
# KUBERCOIN_P2P_BIND=0.0.0.0:18633
# KUBERCOIN_HTTP_BIND=0.0.0.0:8080
# KUBERCOIN_RPC_BIND=0.0.0.0:8332
# KUBERCOIN_WS_BIND=0.0.0.0:9090
# KUBERCOIN_METRICS_BIND=0.0.0.0:9091

# Authentication
KUBERCOIN_API_AUTH_ENABLED=true
# KUBERCOIN_API_KEYS=replace_with_a_testnet_api_key

# Limits and tuning
# KUBERCOIN_MAX_PEERS=125
# KUBERCOIN_RATE_LIMIT_PER_MIN=60
# KUBERCOIN_LOG_LEVEL=info

# Mining
# KUBERCOIN_MINE=true
# KUBERCOIN_MINER_ADDRESS=<your-testnet-address>

# Test mode
KUBERCOIN_TEST_MODE=1